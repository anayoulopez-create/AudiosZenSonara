{
  "functions": {
    "api/**/*.js": { "maxDuration": 60 },
    "api/admin/upload.js": { "maxDuration": 60, "memory": 1024 }
  },
  "headers": [
    {
      "source": "/api/media/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
